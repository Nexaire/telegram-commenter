TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=replace_me
TELEGRAM_SESSION=/data/commenter.session
APPROVAL_BOT_TOKEN=123456:replace_me
APPROVER_USER_IDS=123456789

# Authorization Key из проекта GigaChat API (не временный access token).
GIGACHAT_CREDENTIALS=replace_me
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# Для простого старта false. Для production установите сертификат НУЦ Минцифры
# и включите true; путь внутри контейнера задается в GIGACHAT_CA_BUNDLE_FILE.
GIGACHAT_VERIFY_SSL_CERTS=false
GIGACHAT_CA_BUNDLE_FILE=

DATABASE_PATH=/data/commenter.db
CHANNELS_CONFIG=/app/config/channels.yaml
LOG_LEVEL=INFO
DRY_RUN=true
DAILY_COMMENT_LIMIT=5
PUBLISH_DELAY_MIN_SECONDS=120
PUBLISH_DELAY_MAX_SECONDS=600
MONITOR_LOOKBACK_HOURS=24
MONITOR_POLL_SECONDS=300
BLACKLIST_TOPICS=политика,религия,трагедия,медицина,инвестиционные советы
BRAND_NAMES=My Brand,mybrand
SEND_AS_CHANNEL=
